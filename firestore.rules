rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net - Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isServerTimestamp(val) {
      return val is timestamp || val is string; // Compatible with mock payloads and Firestore Datetime types
    }

    // Users Collection Rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && userId == request.auth.uid;
      allow update: if isOwner(userId) && (!request.resource.data.keys().hasAny(['role', 'isAdmin']));
      allow delete: if false; // Profiles cannot be self-deleted to maintain directory trail integrity
    }

    // Businesses Collection Rules
    match /businesses/{businessId} {
      allow read: if true; // Public directories are viewable by anyone
      allow create: if isSignedIn() && isValidId(businessId) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && (
        isOwner(resource.data.ownerId) || 
        // Allow public to increment ratings and review counters atomically if unauthenticated but safe
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviewsCount']))
      );
      allow delete: if isSignedIn() && isOwner(resource.data.ownerId);
    }

    // Reviews Collection Rules
    match /reviews/{reviewId} {
      allow read: if true; // Reviews are visible to all readers
      allow create: if isSignedIn() && isValidId(reviewId) && exists(/databases/$(database)/documents/businesses/$(request.resource.data.businessId));
      allow update, delete: if isSignedIn() && isOwner(resource.data.userId); // Authenticated writers can modify/remove their own comments
    }

    // Announcements Collection Rules
    match /announcements/{announcementId} {
      allow read: if true; // News board is public
      allow create: if isSignedIn() && isValidId(announcementId);
      allow update: if isSignedIn() && (
        isOwner(resource.data.userId) ||
        // Allow any signed-in user to like announcements
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']))
      );
      allow delete: if isSignedIn() && (isOwner(resource.data.userId) || resource.data.userId == "usr_admin");
    }
  }
}
